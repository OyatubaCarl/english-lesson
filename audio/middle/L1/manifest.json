    {
      "idx": 1,
      "text": "Hello.",
      "para": 1
    },
    {
      "idx": 2,
      "text": "My name is Ken.",
      "para": 1
    },
    {
      "idx": 3,
      "text": "I am ten years old.",
      "para": 1
    },
    {
      "idx": 4,
      "text": "I am a student.",
      "para": 1
    },
    {
      "idx": 5,
      "text": "I live in a small village.",
      "para": 2
    },
    {
      "idx": 6,
      "text": "My family has a father, a mother, a brother, a sister",
      "para": 2
    },
    {
      "idx": 7,
      "text": "and me — five of us.",
      "para": 2
    },
    {
      "idx": 8,
      "text": "We have a dog.",
      "para": 3
    },
    {
      "idx": 9,
      "text": "Its name is Pochi.",
      "para": 3
    },
    {
      "idx": 10,
      "text": "Pochi is really cute, and his eyes are very black.",
      "para": 3
    },
    {
      "idx": 11,
      "text": "Everyone likes him.",
      "para": 3
    },
    {
      "idx": 12,
      "text": "Every morning, I go to school with my sister.",
      "para": 4
    },
    {
      "idx": 13,
      "text": "We are in the same class.",
      "para": 4
    },
    {
      "idx": 14,
      "text": "I like music.",
      "para": 5
    },
    {
      "idx": 15,
      "text": "My brother likes books.",
      "para": 5
    },
    {
      "idx": 16,
      "text": "My sister likes flowers very much.",
      "para": 5
    },
    {
      "idx": 17,
      "text": "Yesterday was a really good day.",
      "para": 6
    },
    {
      "idx": 18,
      "text": "Pochi and I played a lot in the park.",
      "para": 6
    }
  ]
